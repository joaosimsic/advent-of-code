#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: $0 <year> <day> [language]"
    echo "  language defaults to 'rust'"
    exit 1
}

YEAR=${1:-}
DAY=${2:-}
LANG=${3:-rust}

[[ -z "$YEAR" || -z "$DAY" ]] && usage

DAY_PAD=$(printf '%02d' "$DAY")
CNAME="y${YEAR}d${DAY_PAD}"
DIR="${YEAR}/${DAY}/${LANG}"

case "$LANG" in
    rust)
        mkdir -p "$DIR/src"

        cat > "$DIR/Cargo.toml" <<- CARGO
		[package]
		name = "${CNAME}"
		version = "0.1.0"
		edition = "2024"

		[dependencies]
		rust = { path = "../../../common/rust" }
		CARGO

        cat > "$DIR/src/main.rs" <<- RUST
		fn main() {
		    let input = rust::read_stdin();
		    println!("{input}");
		}
		RUST

        echo "Created $DIR"
        ;;
    ts)
        mkdir -p "$DIR"

        cat > "$DIR/package.json" <<- JSON
		{
		  "name": "${CNAME}",
		  "private": true,
		  "dependencies": {
		    "ts": "*"
		  }
		}
		JSON

        cat > "$DIR/tsconfig.json" <<- JSON
		{
		  "extends": "../../../tsconfig.json"
		}
		JSON

        cat > "$DIR/index.ts" <<- TS
		import { readStdin } from "ts";

		const input = await readStdin();
		console.log(input);
		TS

        echo "Created $DIR"
        ;;
    *)
        echo "Unknown language: $LANG"
        exit 1
        ;;
esac
